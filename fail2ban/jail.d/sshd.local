# Copy to /etc/fail2ban/jail.d/sshd.local on the droplet, then restart fail2ban.
# Host-level SSH brute-force protection — the layer where an iptables ban works
# correctly (real source IPs, INPUT chain). Ubuntu 24.04 reads sshd auth from
# journald, hence backend = systemd.
[sshd]
enabled  = true
backend  = systemd
mode     = aggressive
maxretry = 5
findtime = 10m
bantime  = 1h
