{
	# ACME contact for Let's Encrypt. Supplied via the caddy container's env.
	email {$ACME_EMAIL}
}

# Caddy provisions and auto-renews the TLS certificate for this host.
# Vaultwarden's WebSocket notifications are proxied over the same host,
# so no extra websocket config is required.
{$DOMAIN} {
	encode gzip
	reverse_proxy vaultwarden:80
}
