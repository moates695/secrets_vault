# Copy to .env ON THE DROPLET and fill in. NEVER commit the real .env.
#
#   cp .env.example .env && nano .env
#
# ── Public identity ────────────────────────────────────────────────────
# Bare hostname only (no scheme, no trailing slash). Compose adds https://
# TLS is terminated upstream by the existing nginx-proxy-prod (Cloudflare
# Origin cert), so no ACME/Let's Encrypt config is needed here.
DOMAIN=vault.example.com

# ── Admin panel ────────────────────────────────────────────────────────
# Argon2 PHC hash gating /admin. Generate on the droplet with:
#   docker run --rm -it vaultwarden/server:1.36.0 /vaultwarden hash
#
# IMPORTANT — $ escaping: this host's Docker Compose DOES interpolate env_file
# values, so every "$" in the hash must be DOUBLED to "$$" here. After Compose
# interpolation the container receives the original single-$ hash. Example:
#   generated:  $argon2id$v=19$m=65540,t=3,p=4$SALT$HASH
#   in .env:    $$argon2id$$v=19$$m=65540,t=3,p=4$$SALT$$HASH
# Verify with: docker exec vaultwarden printenv ADMIN_TOKEN  (must start "$argon2id$")
ADMIN_TOKEN=REPLACE_WITH_ARGON2_HASH_DOLLARS_DOUBLED

# ── Logging (required for fail2ban to see failed logins) ───────────────
# Writes to ./vw-data/vaultwarden.log on the host, which the fail2ban jail tails.
LOG_FILE=/data/vaultwarden.log
LOG_LEVEL=info
EXTENDED_LOGGING=true

# ── Signup control ─────────────────────────────────────────────────────
# Start "true" to register the super-admin's account, then flip to "false"
# and `docker compose up -d`. Invited addresses can still register.
SIGNUPS_ALLOWED=true
INVITATIONS_ALLOWED=true
# Optional: restrict registration to specific domains (comma-separated).
# SIGNUPS_DOMAINS_WHITELIST=example.com

# ── SMTP (optional — needed for org invites / password-hint emails) ─────
# SMTP_HOST=smtp.example.com
# SMTP_FROM=vault@example.com
# SMTP_PORT=587
# SMTP_SECURITY=starttls
# SMTP_USERNAME=vault@example.com
# SMTP_PASSWORD=
